# ==========================================
# Python & Django REST Framework .gitignore
# ==========================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments (Never commit your dependencies)
venv/
.venv/
env/
.env/
ENV/
pip-wheel-metadata/

# Environment Variables & Secrets (CRITICAL for security)
.env
.secrets
*.env.local

# Databases (Keep local development data local)
*.sqlite3
*.db

# Media & Static Files
# Ignore user-uploaded media files
media/
# Ignore collected static files (generated via collectstatic)
staticfiles/
static_cdn/

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Testing and Coverage
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.coverage

# OS generated files
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db

# Logs
*.log
pip-log.txt